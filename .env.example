# MedSurvey Pro - Docker Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# كلمة مرور MySQL Root
MYSQL_ROOT_PASSWORD=CHANGE_ME_secure_password

# اسم قاعدة البيانات
MYSQL_DATABASE=medsurvey_pro

# رابط اتصال قاعدة البيانات للسيرفر
DATABASE_URL=mysql://root:CHANGE_ME_secure_password@db:3306/medsurvey_pro

# مفتاح توقيع JWT — استخدم قيمة عشوائية طويلة!
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_key
REFRESH_SECRET=CHANGE_ME_use_a_long_random_refresh_secret

# منفذ السيرفر
PORT=3001

# Vite dev proxy target for local development.
# Keep this aligned with server/.env PORT when running npm run dev:all.
VITE_API_PORT=4001
# VITE_API_PROXY_TARGET=http://127.0.0.1:4001
