# MedSurvey Pro - Docker Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك

# كلمة مرور MySQL Root — غيّر القيمة في ملف .env الحقيقي
MYSQL_ROOT_PASSWORD=CHANGE_ME_YOUR_ROOT_PASSWORD

# اسم قاعدة البيانات
MYSQL_DATABASE=medsurvey_pro

# رابط اتصال قاعدة البيانات — استخدم القيم الصحيحة لبيئتك
DATABASE_URL=mysql://root:USER_PLACEHOLDER@db:3306/medsurvey_pro

# مفتاح توقيع JWT — استخدم: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_BYTE_HEX_KEY
REFRESH_SECRET=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_BYTE_HEX_KEY

# Required in production when the first super admin account is created.
SUPER_ADMIN_PASSWORD=CHANGE_ME_YOUR_STRONG_SUPER_ADMIN_PASSWORD

# Optional: lock public survey reads to one tenant in production.
# PUBLIC_TENANT_ID=
# ALLOW_PUBLIC_TENANT_QUERY=false

# منفذ السيرفر
PORT=3001

# Vite dev proxy target for local development.
# Keep this aligned with server/.env PORT when running npm run dev:all.
VITE_API_PORT=4001
# VITE_API_PROXY_TARGET=http://127.0.0.1:4001
