APP_NAME="MedSurvey Pro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
APP_TIMEZONE=Asia/Aden

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD_AT_LEAST_12_CHARS

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=medsurvey
DB_USERNAME=medsurvey
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

JWT_SECRET=CHANGE_ME_GENERATE_WITH_PHP_ARTISAN_JWT_SECRET
FRONTEND_URL=https://your-domain.example
ALLOWED_ORIGINS=https://your-domain.example
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN
CORS_MAX_AGE=600
SANCTUM_STATEFUL_DOMAINS=your-domain.example

DB_BACKUP_RESTORE_ENABLED=false
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_DIR=storage/app/backups

BROADCAST_CONNECTION=null

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=your-domain.example
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VITE_SENTRY_DSN=

HASH_VERIFY=true

# Trusted Proxies — set to your load balancer/CDN IP ranges
TRUSTED_PROXIES=
PUBLIC_TENANT_ID=
PUBLIC_TENANT_QUERY_ALLOWED=false
