{
  "name": "medsurvey-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test -c e2e.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --check \"resources/js/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"resources/js/**/*.{ts,tsx,css,json}\"",
    "format:fix": "prettier --write \"resources/js/**/*.{ts,tsx,css,json}\""
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@fontsource/cairo": "^5.2.7",
    "alpinejs": "^3.15.12",
    "apexcharts": "^5.13.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "laravel-echo": "^2.3.4",
    "lucide": "^1.17.0",
    "pusher-js": "^8.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.17",
    "@testing-library/dom": "^10.4.1",
    "@types/alpinejs": "^3.13.11",
    "@types/file-saver": "^2.0.7",
    "@types/node": "22.19.17",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "laravel-vite-plugin": "^2.1.0",
    "prettier": "^3.8.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "7.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "tmp": "^0.2.6",
    "uuid": "^11.1.0"
  }
}
