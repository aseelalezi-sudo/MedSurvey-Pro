  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "pm2 start ecosystem.config.cjs",
    "stop:prod": "pm2 delete ecosystem.config.cjs",
