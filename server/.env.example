# MedSurvey Pro - Server Environment Variables Example
# Copy this file to '.env' and adjust the variables for your local development environment

# Server Listening Port
PORT=4001

# Prisma Database Connection URL
# Format: mysql://username:password@host:port/database_name
DATABASE_URL="mysql://root:YOUR_DB_PASSWORD@localhost:3306/medsurvey_pro"

# Sentry DSN for error tracking
SENTRY_DSN=

# JSON Web Token (JWT) Secret Keys
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_BYTE_HEX_KEY"
REFRESH_SECRET="CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_BYTE_HEX_KEY"

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS="http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"

# Database Backup Configuration
# DB_BACKUP_ENABLED=true              # Enable/disable automatic backups
# DB_BACKUP_DIR=./backups             # Directory to store backup files
# DB_BACKUP_RETENTION_DAYS=30         # Number of days to keep backups
# DB_BACKUP_MAX_SIZE_MB=0             # Max backup file size in MB (0 = no limit)
