# MedSurvey Pro - Server Environment Variables Example
# Copy this file to '.env' and adjust the variables for your local development environment

# Server Listening Port
PORT=3001

# Prisma Database Connection URL (supports MySQL, PostgreSQL, SQLite, etc.)
# Format: protocol://username:password@host:port/database_name
DATABASE_URL="mysql://root:secure_password@localhost:3306/medsurvey_pro"

# JSON Web Token (JWT) Secret Key for authenticating sessions
# Ensure this is a long, high-entropy random string in production
JWT_SECRET="medsurvey-pro-jwt-secret-key-change-this-in-production-2026-abcxyz"

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS="http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"
