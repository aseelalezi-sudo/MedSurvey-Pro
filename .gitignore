# Dependencies
node_modules/
vendor/

# Build output
dist/
public/build/

# Environment secrets - never commit these
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
storage/logs/

# Database backups
storage/app/backups/

# Local env overrides
*.local

# Testing
coverage/
.phpunit.result.cache
playwright-report/
test-results/

# Laravel generated files
storage/*.key
storage/framework/cache/data/*
!storage/framework/cache/data/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
bootstrap/cache/*.php
!bootstrap/cache/.gitkeep

# Agent workspace
.kilo/
.vite/
