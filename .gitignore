# Dependencies
node_modules/
vendor/

# Build output
dist/
public/build/
public/storage/

# Environment secrets - never commit these
.env
.env.*
!.env.example
!.env.production.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
storage/logs/

# Database backups
storage/app/backups/
storage/app/public/*
!storage/app/public/.gitkeep

# Local env overrides
*.local

# Testing
coverage/
.phpunit.result.cache
playwright-report/
test-results/
storage/framework/testing/

# Laravel generated files
storage/*.key
storage/framework/cache/data/*
!storage/framework/cache/data/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
bootstrap/cache/*.php
!bootstrap/cache/.gitkeep

# Agent workspace
.kilo/
.vite/

# Security patches and artifacts
MedSurvey-Pro-security-fixes.diff
SECURITY_FIXES_APPLIED.md
